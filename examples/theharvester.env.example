# Optional theHarvester API keys. Leave variables empty if you do not use these sources.
# Load example:
#   set -a
#   source examples/theharvester.env.example
#   set +a

THEHARVESTER_SHODAN_KEY=
THEHARVESTER_GITHUB_TOKEN=
THEHARVESTER_HUNTER_KEY=
THEHARVESTER_SECURITYTRAILS_KEY=
THEHARVESTER_VIRUSTOTAL_KEY=
THEHARVESTER_CENSYS_ID=
THEHARVESTER_CENSYS_SECRET=

# Alternative fully custom/extendable mapping:
# THEHARVESTER_API_KEYS_JSON={"shodan":{"key":"..."},"hunter":{"key":"..."},"censys":{"id":"...","secret":"..."}}
